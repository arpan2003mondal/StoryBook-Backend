            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@storybook.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/login",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "login"]
            }
          },
          "description": "Login as admin to access admin-only operations"
        },
        {
          "name": "Admin Logout",
          "request": {
            "method": "POST",
            "header": [
