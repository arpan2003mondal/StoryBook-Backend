              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newUsername\": \"Updated Name\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/change-username",
              "host": ["{{baseUrl}}"],
              "path": ["users", "change-username"]
            }
          },
          "description": "Change user's username/display name (requires authentication)"
        },
        {
          "name": "User Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
