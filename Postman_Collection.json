                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/storybooks/1",
              "host": ["{{baseUrl}}"],
              "path": ["storybooks", "1"]
            }
          }
        },
        {
          "name": "Add Storybook (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"The Hobbit\",\n  \"description\": \"A fantasy adventure about a small hobbit's unexpected journey\",\n  \"authorId\": 4,\n  \"categoryId\": 1,\n  \"price\": 8.99,\n  \"audioUrl\": \"https://archive.org/download/hobbit_librivox/hobbit_64kb.m4b\",\n  \"sampleAudioUrl\": \"https://example.com/samples/hobbit_sample.mp3\",\n  \"coverImageUrl\": \"https://images.unsplash.com/photo-1507842217343-583f20270319?w=400&h=600&fit=crop\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/storybooks",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "storybooks"]
            }
          }
        }
      ]
    },
    {
