  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1️⃣ Send OTP for Registration",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    pm.test(\"OTP sent successfully\", function () {",
                  "        pm.expect(pm.response.code).to.equal(202);",
                  "        pm.expect(pm.response.text()).to.include(\"OTP sent\");",
                  "    });",
                  "    pm.collectionVariables.set(\"registrationEmail\", \"newuser@example.com\");",
                  "} else {",
                  "    pm.test(\"Failed to send OTP\", function () {",
                  "        pm.expect(pm.response.code).to.equal(202);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Password@123\",\n  \"confirmPassword\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["users", "register"]
            }
          },
          "description": "STEP 1: Send registration details and receive OTP via email\n- Response: 202 ACCEPTED\n- OTP is sent to the provided email\n- OTP expires in 10 minutes"
        },
        {
          "name": "2️⃣ Verify OTP & Complete Registration",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.test(\"Registration successful\", function () {",
                  "        pm.expect(pm.response.code).to.equal(201);",
                  "        pm.expect(pm.response.text()).to.include(\"Registration Successful\");",
                  "    });",
                  "} else {",
                  "    pm.test(\"Registration failed\", function () {",
                  "        pm.expect(pm.response.code).to.equal(201);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"otp\": \"123456\",\n  \"registerRequest\": {\n    \"name\": \"New User\",\n    \"email\": \"newuser@example.com\",\n    \"password\": \"Password@123\",\n    \"confirmPassword\": \"Password@123\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/verify-registration",
              "host": ["{{baseUrl}}"],
              "path": ["users", "verify-registration"]
            }
          },
          "description": "STEP 2: Verify OTP received in email and complete registration\n- Request: Email, OTP (from email), and registration details\n- Response: 201 CREATED with success message\n- User account is created with verified email\n- Wallet (1000 RS) and Cart are auto-created"
        },
        {
          "name": "User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var token = pm.response.text().trim();",
                  "    pm.collectionVariables.set(\"userToken\", token);",
                  "    pm.test(\"Login successful and token saved\", function () {",
                  "        pm.expect(pm.response.code).to.equal(200);",
                  "        pm.expect(token).to.be.ok;",
                  "    });",
                  "} else {",
                  "    pm.test(\"Login failed\", function () {",
                  "        pm.expect(pm.response.code).to.equal(200);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@storybook.com\",\n  \"password\": \"User@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["users", "login"]
            }
          },
          "description": "Login with registered email and password\n- Returns JWT token for authenticated requests\n- Token valid for 10 hours"
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
